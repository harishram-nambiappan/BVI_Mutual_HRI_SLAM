# Copy this file to ".env" (same folder) and fill in your values.
# The .env file is gitignored and will NOT be committed.

# Your OpenAI API key (used by the phone for transcription)
OPENAI_API_KEY=sk-replace-me

# URL of the desktop Python receiver on your local network.
# Use your computer's LAN IP and the port the receiver listens on (8000).
SERVER_URL=http://192.168.1.153:8000

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/screen_padding"
    tools:context=".ImageAnalysis">

    <TextView
        android:id="@+id/analysisTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/analysis_title"
        android:textAppearance="@style/TextAppearance.App.Title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/analysisSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_s"
        android:text="@string/analysis_subtitle"
        android:textAppearance="@style/TextAppearance.App.Subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/analysisTitle" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageCard"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginTop="@dimen/space_l"
        app:cardBackgroundColor="@color/surface_variant"
        app:cardCornerRadius="@dimen/card_corner"
        app:cardElevation="0dp"
        app:strokeColor="@color/outline"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/analysisSubtitle">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/analysisImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_captured_image"
                android:scaleType="centerCrop" />

            <View
                android:id="@+id/scanLine"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@drawable/bg_scan_line" />
        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/analysisCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_m"
        android:layout_marginBottom="@dimen/space_l"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="@dimen/card_corner"
        app:cardElevation="0dp"
        app:strokeColor="@color/outline"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@+id/addSpeechBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/space_m">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/analysis_result_header"
                    android:textAppearance="@style/TextAppearance.App.Label" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/analysisProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/accent"
                    app:indicatorSize="20dp"
                    app:trackColor="@color/accent_container"
                    app:trackThickness="2dp" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/space_s"
                android:layout_weight="1"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/analysisText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.2"
                    android:text="@string/analyzing"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textIsSelectable="true" />
            </ScrollView>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/addSpeechBtn"
        style="@style/Widget.App.Button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_m"
        android:enabled="false"
        android:text="@string/add_speech"
        app:icon="@drawable/ic_mic"
        app:layout_constraintBottom_toTopOf="@+id/retakeBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/retakeBtn"
        style="@style/Widget.App.Button.Outlined"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_s"
        android:text="@string/retake"
        app:icon="@drawable/ic_camera"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
